# Copia in .env.local per `vercel dev` o sviluppo backend locale.
# Su Vercel: imposta le stesse chiavi in Environment Variables.

# ─── Supabase ───────────────────────────────────────────────
# URL del progetto Supabase (es. https://xyzcompany.supabase.co)
VITE_SUPABASE_URL=
# Chiave pubblica (anon key) del progetto Supabase
VITE_SUPABASE_ANON_KEY=

# ─── Google Drive (legacy, opzionale) ──────────────────────
# JSON completo del service account Google (stringa su una riga)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ID cartella Drive (dall'URL) — condivisa con client_email del service account
# GOOGLE_DRIVE_FOLDER_ID=

# Stesso valore su server e client se vuoi proteggere le API di upload
# UPLOAD_API_SECRET=
# VITE_UPLOAD_API_SECRET=
